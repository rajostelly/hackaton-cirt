# Groq AI — free tier, 1 000 req/jour (llama-3.3-70b)
# Créer une clé sur https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# VirusTotal (https://www.virustotal.com/gui/my-apikey)
VT_API_KEY=your_virustotal_key_here

# Wazuh Indexer (OpenSearch — port 9200)
WAZUH_INDEXER_HOST=localhost
WAZUH_INDEXER_PORT=9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASSWORD=SecretPassword
WAZUH_INDEXER_VERIFY_CERTS=false

# Wazuh Manager REST API (port 55000)
WAZUH_MANAGER_URL=https://localhost:55000
WAZUH_MANAGER_USER=wazuh-wui
WAZUH_MANAGER_PASSWORD=MyS3cr37P450r.*-
WAZUH_MANAGER_VERIFY_SSL=false

# Palo Alto NGFW — PAN-OS XML API
# base_url = https://<ip-ou-host-du-firewall>
# api_key  = généré via : curl -k "https://<fw>/api/?type=keygen&user=<u>&password=<p>"
PANOS_BASE_URL=https://your-firewall-host
PANOS_API_KEY=your_panos_api_key_here
PANOS_VERIFY_SSL=false

# CrowdStrike Falcon — API OAuth2 (Support > API Clients and Keys)
# base_url selon la région : us-1 https://api.crowdstrike.com |
#   us-2 https://api.us-2.crowdstrike.com | eu-1 https://api.eu-1.crowdstrike.com
CROWDSTRIKE_BASE_URL=https://api.crowdstrike.com
CROWDSTRIKE_CLIENT_ID=your_client_id_here
CROWDSTRIKE_CLIENT_SECRET=your_client_secret_here
CROWDSTRIKE_VERIFY_SSL=true
